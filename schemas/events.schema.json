{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "title": "WGS Cockpit Event",
  "type": "object",
  "required": ["event_type", "ts"],
  "anyOf": [
    { "required": ["run_id"] },
    { "required": ["job_id"] }
  ],
  "properties": {
    "event_type": {"type": "string"},
    "job_id": {"type": "string"},
    "run_id": {"type": "string"},
    "stage": {"type": "string"},
    "payload": {"type": "object"},
    "progress": {"type": "number", "minimum": 0, "maximum": 100},
    "ts": {"type": "string", "format": "date-time"}
  }
}
